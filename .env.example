###############################################################################
# k3d-lab configuration. Copy to `.env` and edit. `.env` is gitignored.
#   cp .env.example .env
###############################################################################

# --- Host / cluster identity --------------------------------------------------
LOCAL_HOST=homelab                       # short name for this host
CLUSTER_NAME=${LOCAL_HOST}        # k3d cluster + kube context name
API_SERVER_FQDN=${LOCAL_HOST}.yourcompany.lan
API_SERVER_PORT=16443

# --- Versions -----------------------------------------------------------------
K3S_VERSION=v1.35.0-k3s3
CILIUM_VERSION=1.19.0
GATEWAY_API_VERSION=v1.2.1             # kubernetes-sigs/gateway-api release tag
CERT_MANAGER_VERSION=v1.16.2
COREDNS_CHART_VERSION=1.39.2           # coredns/helm chart version (cluster kube-dns)

# --- Cluster sizing -----------------------------------------------------------
SERVER_COUNT=1
AGENT_COUNT=1
CLUSTER_SUBNET=172.20.40.0/24          # docker network for k3d nodes

# --- LoadBalancer IP pool (Cilium LB-IPAM + L2 announcements) -----------------
# The pool must live on a subnet your LAN can route/ARP to (bridged to eth0).
LB_CIDR=172.28.210.0/24
DNS_LB_IP=172.28.210.53                # pinned IP for the authoritative DNS
GATEWAY_LB_IP=172.28.210.80           # pinned IP for the shared Gateway (HTTP/HTTPS)

# --- DNS ----------------------------------------------------------------------
LOCAL_TLD=home.lan                     # authoritative local zone
UPSTREAM_DNS="1.1.1.1 9.9.9.9"         # public resolvers (quote it — value has a space)

# --- In-cluster image registry (optional; only used with --with-registry) -----
# Push images from any LAN device (docker push registry.home.lan/...) and the
# k3s nodes pull them automatically. HTTPS via the internal CA; no auth by default.
REGISTRY_LB_IP=172.28.210.81           # pinned IP for the in-cluster registry
REGISTRY_HOST=registry.${LOCAL_TLD}    # registry hostname (resolves via authoritative DNS)

# --- Storage on the host device (PVCs land here via local-path) ---------------
CLUSTER_VOLUME_STORE=/db/srv/k3d-store

# --- Tailscale subnet router (optional; only used with --with-router) ----------
# Leave blank to skip. NEVER commit real values — .env is gitignored.
TS_AUTHKEY=
TS_LOGIN_SERVER=
TS_ROUTES=${LB_CIDR}
